{
  "name": "lanhu-context-mcp",
  "type": "module",
  "version": "0.0.5",
  "packageManager": "pnpm@10.33.0",
  "description": "Turn a Lanhu design into context for AI to generate code and recreate pages",
  "author": "REFINIST",
  "license": "MIT",
  "homepage": "https://github.com/refinist/lanhu-context-mcp#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/refinist/lanhu-context-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/refinist/lanhu-context-mcp/issues"
  },
  "keywords": [
    "lanhu",
    "lanhuapp",
    "lanhu-context-mcp",
    "lanhu-mcp",
    "蓝湖",
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "design",
    "design-to-code",
    "design-tokens",
    "design-context",
    "html",
    "css",
    "tailwind",
    "tailwindcss",
    "ai",
    "llm",
    "claude",
    "claude-code",
    "cursor",
    "codex"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "bin": {
    "lanhu-context-mcp": "dist/run.mjs"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "docs:dev": "vitepress dev docs --open",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "worker:dev": "pnpm docs:build && wrangler dev",
    "worker:deploy": "pnpm docs:build && wrangler deploy",
    "play": "pnpm run -C playground dev",
    "play:clean": "pnpm run -C playground clean",
    "start": "node dist/run.mjs",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "test:integration": "RUN_INTEGRATION=1 vitest run src/tools/__tests__/get-design-context.http.integration.spec.ts src/tools/__tests__/get-design-context.stdio.integration.spec.ts",
    "test:integration:http": "RUN_INTEGRATION=1 vitest run src/tools/__tests__/get-design-context.http.integration.spec.ts",
    "test:integration:stdio": "RUN_INTEGRATION=1 vitest run src/tools/__tests__/get-design-context.stdio.integration.spec.ts",
    "test:integration:files": "RUN_INTEGRATION=1 vitest run src/tools/__tests__/get-design-context.http.integration.spec.ts src/tools/__tests__/get-design-context.stdio.integration.spec.ts -t \"mode=files\"",
    "test:integration:files:http": "RUN_INTEGRATION=1 vitest run src/tools/__tests__/get-design-context.http.integration.spec.ts -t \"mode=files\"",
    "test:integration:files:stdio": "RUN_INTEGRATION=1 vitest run src/tools/__tests__/get-design-context.stdio.integration.spec.ts -t \"mode=files\"",
    "typecheck": "tsgo --noEmit",
    "prepack": "node scripts/strip-install-hooks.ts",
    "postpack": "node scripts/restore-install-hooks.ts",
    "lint": "eslint .",
    "lint:fix": "pnpm run lint --fix",
    "format": "prettier --cache --write .",
    "prepublishOnly": "pnpm run build",
    "release": "bumpp",
    "preinstall": "npx only-allow pnpm",
    "postinstall": "simple-git-hooks"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "axios": "^1.15.0",
    "cleye": "^2.6.0",
    "css-to-tailwindcss": "^1.0.5",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@refinist/eslint-config": "^1.3.0",
    "@refinist/prettier-config": "^1.2.0",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "@typescript/native-preview": "7.0.0-dev.20260422.1",
    "@vitest/coverage-v8": "4.1.4",
    "bumpp": "^11.0.1",
    "eslint": "^10.2.1",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "simple-git-hooks": "^2.13.1",
    "tsdown": "^0.22.0",
    "typescript": "^6.0.3",
    "vitepress": "2.0.0-alpha.17",
    "vitepress-component-medium-zoom": "^1.1.1",
    "vitest": "^4.1.4",
    "wrangler": "^4.80.0"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged"
  },
  "lint-staged": {
    "*.{json,jsonc,md,yml,yaml,css,html}": [
      "prettier --cache --write"
    ],
    "*.{js,mjs,cjs,ts,mts,cts,tsx,vue}": [
      "eslint --cache --fix",
      "prettier --cache --write"
    ]
  },
  "prettier": "@refinist/prettier-config"
}
